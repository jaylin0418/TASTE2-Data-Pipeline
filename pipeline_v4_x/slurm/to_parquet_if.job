#!/bin/bash
#SBATCH -J to_parquet_if
#SBATCH -A MST115022
#SBATCH -p 8gpus
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --gpus-per-node=1
#SBATCH --cpus-per-task=16
#SBATCH --mem=64G
#SBATCH --time=04:00:00
#SBATCH -o /work/jaylin0418/IF_data_generation/logs/to_parquet_if_%j.out
#SBATCH -e /work/jaylin0418/IF_data_generation/logs/to_parquet_if_%j.err

echo "=========================================="
echo "Job: to_parquet_if"
echo "Job ID: $SLURM_JOB_ID  Node: $SLURM_NODELIST"
echo "Start: $(date)"
echo "=========================================="

DATA_DIR=/work/jaylin0418/IF_data_generation/tts_output/full
OUT_DIR=/work/jaylin0418/IF_data_generation/parquet_output
SCRIPT=/work/jaylin0418/IF_data_generation/to_parquet_if.py

mkdir -p "$OUT_DIR"

/home/jaylin0418/miniconda3/envs/breezyvoice_py310/bin/python "$SCRIPT" \
    --data-dir "$DATA_DIR" \
    --out-dir  "$OUT_DIR" \
    --chunk-gb 1.0 \
    --prefix   if

echo "=========================================="
echo "Done: $(date)"
echo "=========================================="

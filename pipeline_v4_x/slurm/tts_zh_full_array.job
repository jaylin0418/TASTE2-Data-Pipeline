#!/bin/bash
#SBATCH -J tts_zh_full
#SBATCH -A MST115022
#SBATCH -p 8gpus
#SBATCH --array=0-7
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --gpus-per-node=1
#SBATCH --cpus-per-task=8
#SBATCH --mem=64G
#SBATCH --time=20:00:00
#SBATCH -o /work/jaylin0418/IF_data_generation/logs/tts_zh_full_%A_%a.out
#SBATCH -e /work/jaylin0418/IF_data_generation/logs/tts_zh_full_%A_%a.err

echo "=========================================="
echo "Job: TTS zh full (worker $SLURM_ARRAY_TASK_ID / 8)"
echo "Job ID: $SLURM_JOB_ID  Array: $SLURM_ARRAY_JOB_ID  Node: $SLURM_NODELIST"
echo "Start: $(date)"
echo "=========================================="

SIF=/home/jaylin0418/SpeechLab/env/cosyvoice2_v4.sif
PYTHON=/opt/conda/envs/cosyvoice/bin/python
BIND="--bind /home/jaylin0418:/home/jaylin0418 --bind /work/jaylin0418:/work/jaylin0418"

INPUT=/work/jaylin0418/IF_data_generation/output_zh/full/dataset.jsonl
OUTPUT=/work/jaylin0418/IF_data_generation/tts_output_zh/full
MODEL_DIR=/work/jaylin0418/cog-IndexTTS-2/checkpoints
SPK_DIR=/work/jaylin0418/IF_data_generation/ref_audio_zh
EMO_REF_DIR=/home/jaylin0418/SpeechLab/ref_audio/eleven_lab_emotion

mkdir -p /work/jaylin0418/IF_data_generation/logs
mkdir -p /work/jaylin0418/IF_data_generation/tts_output_zh/full

singularity exec --nv $BIND $SIF bash -c "
    PIP_USER=false $PYTHON -m pip install \
        json5 audiostretchy sentencepiece WeTextProcessing cn2an g2p-en jieba \
        omegaconf munch einops textstat ffmpeg-python \
        -q --target /work/jaylin0418/model_merging/pip_packages 2>&1 | tail -3
    export PYTHONNOUSERSITE=1
    export PYTHONPATH=/opt/conda/envs/cosyvoice/lib/python3.10/site-packages:/home/jaylin0418/SpeechLab/Nano4:/work/jaylin0418/model_merging/pip_packages
    export HF_HOME=/work/jaylin0418/model_merging/models/hf_cache
    $PYTHON /work/jaylin0418/IF_data_generation/tts_if_data_zh.py \
        --input           $INPUT \
        --output          $OUTPUT \
        --model_dir       $MODEL_DIR \
        --spk_dir         $SPK_DIR \
        --emo_ref_dir     $EMO_REF_DIR \
        --sample_rate     24000 \
        --num_workers     8 \
        --worker_id       \$SLURM_ARRAY_TASK_ID
" 2>&1

echo "=========================================="
echo "End: $(date)"
echo "=========================================="
